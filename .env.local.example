# Google Service Account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account-email@project.iam.gserviceaccount.com"

# Copy the private_key value from the downloaded JSON key file.
# Keep the quotes. The \n sequences will be resolved by the API route.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The long ID in the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID="your_google_sheet_id_here"

# Exact name of the tab/sheet to append rows to (e.g. "Sheet1" or "Inscrições")
GOOGLE_SHEET_TAB="your_tab_name_here"

# Kill Switch (set to true to enable admissions form, false to show closed state)
ADMISSIONS_OPEN=false
